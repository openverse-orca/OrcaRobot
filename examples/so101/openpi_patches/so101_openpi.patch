+@dataclasses.dataclass(frozen=True)
+class LeRobotS6DataConfig(DataConfigFactory):
+    """
+    Data config for the S6 (SO-101) custom dataset in LeRobot format.
+
+    Remaps the dataset's flat parquet keys to the keys expected by LiberoInputs:
+      observation.images.front  → observation/image
+      observation.images.wrist  → observation/wrist_image
+      observation.state         → observation/state
+      action                    → actions
+    """
+
+    @override
+    def create(self, assets_dirs: pathlib.Path, model_config: _model.BaseModelConfig) -> DataConfig:
+        repack_transform = _transforms.Group(
+            inputs=[
+                _transforms.RepackTransform(
+                    {
+                        "observation/image": "observation.images.front",
+                        "observation/wrist_image": "observation.images.wrist",
+                        "observation/state": "observation.state",
+                        "actions": "action",
+                        "prompt": "prompt",
+                    }
+                )
+            ]
+        )
+
+        data_transforms = _transforms.Group(
+            inputs=[libero_policy.LiberoInputs(model_type=model_config.model_type)],
+        )
+
+        model_transforms = ModelTransformFactory()(model_config)
+
+        return dataclasses.replace(
+            self.create_base_config(assets_dirs, model_config),
+            repack_transforms=repack_transform,
+            data_transforms=data_transforms,
+            model_transforms=model_transforms,
+            action_sequence_keys=("action",),
+        )
+
+
